<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>FreePlay | Play Free Browser Games</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
    <div class="logo">🎮 FreePlay</div>
    <nav>
        <a href="#">Home</a>
        <a href="#">Games</a>
        <a href="#">About</a>
    </nav>
</header>

<section class="hero">
    <h1>Play Free Games Instantly</h1>
    <p>No downloads. No signups. Just fun.</p>
</section>

<section class="games">
    <h2>Featured Game</h2>
    <div class="game-container">
        <canvas id="gameCanvas"></canvas>
        <button onclick="startGame()">Start Game</button>
    </div>
</section>

<footer>
    © 2026 FreePlay Games. All rights reserved.
</footer>

<script src="script.js"></script>
</body>
</html>
